# Public site URL (no trailing slash). Used for sitemap, OG tags and JSON-LD.
NEXT_PUBLIC_SITE_URL=https://www.abcswimmingpoolservice.com

# Google Analytics 4 — replace [GA_MEASUREMENT_ID] with your ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=[GA_MEASUREMENT_ID]

# Google Search Console verification — replace [GSC_VERIFICATION_CODE] with the content value from GSC
NEXT_PUBLIC_GSC_VERIFICATION_CODE=[GSC_VERIFICATION_CODE]

# Yelp Review Badge — replace [YELP_BUSINESS_ID] from Yelp for Business → Get Reviews Widget
NEXT_PUBLIC_YELP_BUSINESS_ID=[YELP_BUSINESS_ID]
